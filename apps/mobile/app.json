{
  "expo": {
    "name": "εκκλησία",
    "slug": "ekklesia-gr",
    "version": "1.0.20",
    "orientation": "portrait",
    "icon": "./assets/pnx.png",
    "scheme": "ekklesia",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/pnx.png",
      "resizeMode": "contain",
      "backgroundColor": "#93c5fd"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "gr.ekklesia.app",
      "icon": "./assets/pnx.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#93c5fd"
      },
      "edgeToEdgeEnabled": false,
      "jsEngine": "hermes",
      "package": "ekklesia.gr",
      "versionCode": 49,
      "permissions": [
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "USE_BIOMETRIC"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ekklesia.gr",
              "pathPrefix": "/el/bills/"
            },
            {
              "scheme": "https",
              "host": "ekklesia.gr",
              "pathPrefix": "/en/bills/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "./plugins/with-react-native-engine",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#2563eb"
        }
      ]
    ],
    "extra": {
      "distributionChannel": "direct",
      "buildFlavor": "direct",
      "zkSemaphoreEnabled": true,
      "eas": {
        "projectId": "f6cfa7b1-ff85-4020-ac35-94d3774615fd"
      }
    },
    "owner": "kaspartisan"
  }
}
