FROM node:20-alpine AS builder
WORKDIR /app
COPY apps/web/package*.json ./
# --legacy-peer-deps: eslint peer-dep conflict in this monorepo (per CLAUDE.md)
RUN npm ci --legacy-peer-deps
COPY apps/web/ .
# Copy docs/ static content (GitHub Pages site) into public/ so Next.js
# serves wiki, votes, tickets, community, SEO files as static assets.
# Build context is repo root (../../ from compose), so docs/ is accessible.
COPY docs/wiki/ ./public/wiki/
COPY docs/votes/ ./public/votes/
COPY docs/tickets/ ./public/tickets/
COPY docs/logo/ ./public/logo/
COPY docs/animations/ ./public/animations/
COPY docs/index.html docs/community.html docs/govgr-dimos.html docs/parliament.jpg docs/favicon.ico ./public/
COPY docs/download/ ./public/download/
COPY docs/embed/ ./public/embed/
COPY docs/robots.txt docs/sitemap.xml docs/llms.txt ./public/
ENV NEXT_TELEMETRY_DISABLED=1
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production NEXT_TELEMETRY_DISABLED=1
RUN addgroup -g 1001 -S nodejs && adduser -S nextjs -u 1001
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
USER nextjs
EXPOSE 3000
CMD ["node", "server.js"]
