# Separate HMAC key for GitHub Parliament source-text attestations.
# Required only for verified official-text imports; never reuse ADMIN_KEY.
PARLIAMENT_IMPORT_ATTESTATION_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING

# Payment intake is fail-closed until the legal recipient and tax/document
# workflow are approved. Never commit real values.
PAYMENTS_INTAKE_GATE=
STRIPE_WEBHOOK_SECRET=
PAYPAL_RECEIVER_EMAIL=
PAYPAL_MERCHANT_ID=
PAYPAL_IPN_URL=https://ipnpb.paypal.com/cgi-bin/webscr
BTC_ADDRESS=
LTC_ADDRESS=
ARWEAVE_ADDRESS=

# Re-enable only with the exact reviewed value and with public links configured
# to provide an allowed donation purpose: infrastructure_support or
# developer_support. HLR provider credits are an operating expense and are not
# accepted or sold through this intake.
# PAYMENTS_INTAKE_GATE=legal_recipient_confirmed

# Provider events remain PII-free and are available through the authenticated
# admin endpoint or, when separately enabled, the private signed export.
# Private finance export is independently fail-closed. Keep all values empty
# until the matching private receiver secret is installed out of band.
FINANCE_EXPORT_ENABLED=false
FINANCE_EXPORT_URL=
FINANCE_EXPORT_SECRET=
