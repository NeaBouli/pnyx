POSTGRES_DB=ekklesia_prod
POSTGRES_USER=ekklesia
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
SERVER_SALT=REPLACE_WITH_32_CHAR_RANDOM_STRING
ACME_EMAIL=REPLACE_WITH_ACME_EMAIL

# ── MOD-08 Arweave ────────────────────────────────────────
# Pfad zur Arweave Wallet JSON Datei (leer = Dry Run)
ARWEAVE_WALLET_PATH=/opt/ekklesia/arweave-wallet.json

# ── MOD-01 HLR Provider ──────────────────────────────────────
# Provider: hlrlookups.com (default) oder melrose
# Crypto prepaid — ~$0.002/Query — 500 Nutzer = $1
HLRLOOKUPS_PROVIDER=hlrlookups
HLRLOOKUPS_USERNAME=REPLACE_WITH_USERNAME
HLRLOOKUPS_PASSWORD=REPLACE_WITH_PASSWORD
# Alternative: Melrose Labs
# HLRLOOKUPS_PROVIDER=melrose
# MELROSE_API_KEY=REPLACE_WITH_KEY

# ── MOD-10 AI Scraper (Self-Hosted — kein API Key nötig)
# Ollama läuft im Docker Container auf Hetzner
# Modell: docker exec ekklesia-ollama ollama pull llama3.2
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
# Optional: HuggingFace Free Tier als L2 Fallback
# HF_API_KEY=hf_...

# ── MOD-09 gov.gr OAuth (Alpha — nach Legitimacy Gates) ──
# Aktivierung: 500+ Nutzer + 3+ NGOs + gov.gr Genehmigung
# Anfrage: https://www.gsrt.gr
GOVGR_CLIENT_ID=REPLACE_AFTER_APPROVAL
GOVGR_CLIENT_SECRET=REPLACE_AFTER_APPROVAL
GOVGR_REDIRECT_URI=https://ekklesia.gr/auth/govgr/callback
