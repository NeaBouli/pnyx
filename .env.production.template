POSTGRES_DB=ekklesia_prod
POSTGRES_USER=ekklesia
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ENVIRONMENT=production
SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING
SERVER_SALT=REPLACE_WITH_32_CHAR_RANDOM_STRING
ACME_EMAIL=REPLACE_WITH_ACME_EMAIL

# ── Admin/Demo Test Defaults ─────────────────────────────────
# Peloponnese / Kalamata test scope used by admin QR accounts + DEMO-123.
ADMIN_TEST_DEFAULT_PERIFERIA_ID=6
ADMIN_TEST_DEFAULT_DIMOS_ID=22
DEMO_REP_PERIFERIA_ID=6
DEMO_REP_DIMOS_ID=22
DEMO_REP_REGION=Πελοποννήσου
DEMO_REP_MUNICIPALITY=Καλαμάτας

# ── MOD-24 DiscourseConnect SSO Bridge ──────────────────────
# HMAC secret for Discourse ↔ pnyx SSO signature verification
DISCOURSE_SSO_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
# Salt for deriving anonymous forum external_id from nullifier_hash
FORUM_SSO_SALT=REPLACE_WITH_32_CHAR_RANDOM_STRING

# ── MOD-08 Arweave ────────────────────────────────────────
# Pfad zur Arweave Wallet JSON Datei (leer = Dry Run)
ARWEAVE_WALLET_PATH=/opt/ekklesia/arweave-wallet.json

# ── MOD-01 HLR Provider ──────────────────────────────────────
# Provider: hlrlookups.com (default) oder melrose
# Crypto prepaid — ~$0.002/Query — 500 Nutzer = $1
HLRLOOKUPS_PROVIDER=hlrlookups
HLRLOOKUPS_USERNAME=REPLACE_WITH_USERNAME
HLRLOOKUPS_PASSWORD=REPLACE_WITH_PASSWORD
# Alternative: Melrose Labs
# HLRLOOKUPS_PROVIDER=melrose
# MELROSE_API_KEY=REPLACE_WITH_KEY

# ── MOD-18 Payments (fail-closed) ─────────────────────────────
# Keep the gate empty until legal recipient, document policy, provider
# fulfillment and sandbox E2E are approved. Never commit runtime values.
PAYMENTS_INTAKE_GATE=
STRIPE_WEBHOOK_SECRET=
PAYPAL_RECEIVER_EMAIL=
PAYPAL_MERCHANT_ID=
PAYPAL_IPN_URL=https://ipnpb.paypal.com/cgi-bin/webscr
BTC_ADDRESS=
LTC_ADDRESS=
ARWEAVE_ADDRESS=

# Private PII-free finance handoff. Keep disabled until the matching secret and
# HTTPS receiver are configured outside this public repository.
FINANCE_EXPORT_ENABLED=false
FINANCE_EXPORT_URL=
FINANCE_EXPORT_SECRET=

# ── MOD-10 AI Scraper (Self-Hosted — kein API Key nötig)
# Ollama läuft im Docker Container auf Hetzner
# Modell: docker exec ekklesia-ollama ollama pull llama3.2
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2
# Optional: HuggingFace Free Tier als L2 Fallback
# HF_API_KEY=hf_...

# ── MOD-09 gov.gr OAuth (Alpha — nach Legitimacy Gates) ──
# Aktivierung: 500+ Nutzer + 3+ NGOs + gov.gr Genehmigung
# Anfrage: https://www.gsrt.gr
GOVGR_CLIENT_ID=REPLACE_AFTER_APPROVAL
GOVGR_CLIENT_SECRET=REPLACE_AFTER_APPROVAL
GOVGR_REDIRECT_URI=https://ekklesia.gr/auth/govgr/callback
