#!/usr/bin/env bash
set -euo pipefail

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

ROOT_PATH="${ROOT_PATH:-/}"
WARN_PERCENT="${WARN_PERCENT:-85}"
CLEAN_PERCENT="${CLEAN_PERCENT:-90}"
CRITICAL_PERCENT="${CRITICAL_PERCENT:-95}"
EXTRA_CAPACITY_PATHS="${EXTRA_CAPACITY_PATHS:-}"
EXTRA_WARN_PERCENT="${EXTRA_WARN_PERCENT:-85}"
EXTRA_CLEAN_PERCENT="${EXTRA_CLEAN_PERCENT:-90}"
EXTRA_CRITICAL_PERCENT="${EXTRA_CRITICAL_PERCENT:-95}"
BUILD_CACHE_MIN_AGE="${BUILD_CACHE_MIN_AGE:-72h}"
JOURNAL_MAX_SIZE="${JOURNAL_MAX_SIZE:-300M}"
LOGROTATE_CONFIG="${LOGROTATE_CONFIG:-/etc/logrotate.d/docker-containers}"
LOG_FILE="${LOG_FILE:-/var/log/safe-disk-guard.log}"
STATUS_FILE="${STATUS_FILE:-/var/log/safe-disk-guard.status}"
LOCK_FILE="${LOCK_FILE:-/run/safe-disk-guard.lock}"

log() {
  printf '%s %s\n' "$(date -Is)" "$*" | tee -a "$LOG_FILE"
}

write_status() {
  local state="$1"
  shift
  printf '%s state=%s %s\n' "$(date -Is)" "$state" "$*" >"$STATUS_FILE"
}

usage_percent() {
  df --output=pcent "$ROOT_PATH" | awk 'NR == 2 { gsub(/%/, "", $1); print $1 }'
}

path_usage_percent() {
  local path="$1"
  df --output=pcent "$path" | awk 'NR == 2 { gsub(/%/, "", $1); print $1 }'
}

path_available() {
  local path="$1"
  df -h --output=avail "$path" | awk 'NR == 2 { print $1 }'
}

path_source() {
  local path="$1"
  df --output=source "$path" | awk 'NR == 2 { print $1 }'
}

extra_capacity_status() {
  local status=""
  local path usage avail source state

  for path in $EXTRA_CAPACITY_PATHS; do
    if ! df "$path" >/dev/null 2>&1; then
      log "EXTRA: ${path} unavailable" >/dev/null
      status="${status} extra:${path}=unavailable"
      continue
    fi

    usage="$(path_usage_percent "$path")"
    avail="$(path_available "$path")"
    source="$(path_source "$path")"
    state="ok"

    if [ "$usage" -ge "$EXTRA_CRITICAL_PERCENT" ]; then
      state="critical"
    elif [ "$usage" -ge "$EXTRA_WARN_PERCENT" ]; then
      state="warning"
    fi

    log "EXTRA: ${path} source=${source} usage=${usage}% avail=${avail} state=${state}" >/dev/null
    status="${status} extra:${path}=${usage}%/${avail}/${state}"
  done

  printf '%s' "$status"
}

extra_capacity_max_usage() {
  local maximum=0
  local path usage

  for path in $EXTRA_CAPACITY_PATHS; do
    if ! df "$path" >/dev/null 2>&1; then
      continue
    fi
    usage="$(path_usage_percent "$path")"
    if [ "$usage" -gt "$maximum" ]; then
      maximum="$usage"
    fi
  done

  printf '%s' "$maximum"
}

has_active_docker_build() {
  ps -eo args= | grep -E '(^|[[:space:]])(docker|docker-compose|buildctl)([[:space:]].*)?(build|buildx|bake)([[:space:]]|$)' | grep -v grep >/dev/null 2>&1
}

run_cmd() {
  log "RUN: $*"
  "$@" >>"$LOG_FILE" 2>&1 || log "WARN: command failed: $*"
}

safe_log_maintenance() {
  if [ -f "$LOGROTATE_CONFIG" ]; then
    run_cmd logrotate "$LOGROTATE_CONFIG"
  fi

  if [ -d /var/lib/docker/containers ]; then
    find /var/lib/docker/containers -type f \
      \( -name '*-json.log.[0-9]' -o -name '*-json.log.[0-9][0-9]' \) \
      -size +50M -print -exec gzip -f -- {} \; >>"$LOG_FILE" 2>&1 || true
  fi

  if command -v journalctl >/dev/null 2>&1; then
    run_cmd journalctl --vacuum-size="$JOURNAL_MAX_SIZE"
  fi
}

safe_cache_maintenance() {
  local emergency="${1:-false}"
  run_cmd apt-get clean

  if ! command -v docker >/dev/null 2>&1; then
    log "SKIP: docker not installed"
    return
  fi

  if has_active_docker_build; then
    log "SKIP: active docker build detected; not pruning build cache"
    return
  fi

  if [ "$emergency" = "true" ]; then
    run_cmd docker builder prune -af
  else
    run_cmd docker builder prune -af --filter "until=$BUILD_CACHE_MIN_AGE"
  fi
}

record_cleanup_result() {
  local before="$1"
  local after="$2"

  if [ "$after" -lt "$CLEAN_PERCENT" ]; then
    write_status "ok" "before=${before}% after=${after}% threshold=${CLEAN_PERCENT}%"
    return
  fi

  if [ "$after" -ge "$before" ]; then
    log "WARN: cleanup ineffective; usage remains ${after}% after safe cleanup. Manual capacity review needed; likely active Docker/containerd data outside automatic cleanup policy."
    write_status "cleanup_ineffective" "before=${before}% after=${after}% threshold=${CLEAN_PERCENT}% action=manual_capacity_review"
    return
  fi

  log "WARN: cleanup incomplete; usage still ${after}% after safe cleanup. Manual capacity review needed before deleting active images, volumes, backups, or project data."
  write_status "cleanup_incomplete" "before=${before}% after=${after}% threshold=${CLEAN_PERCENT}% action=manual_capacity_review"
}

main() {
  mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$STATUS_FILE")"

  exec 9>"$LOCK_FILE"
  if ! flock -n 9; then
    log "SKIP: another safe-disk-guard run is active"
    write_status "locked" "root=${ROOT_PATH}"
    exit 0
  fi

  local before after extra_before extra_after effective_before effective_after emergency
  before="$(usage_percent)"
  log "START: ${ROOT_PATH} usage ${before}%"
  local extra_status
  extra_status="$(extra_capacity_status)"
  extra_before="$(extra_capacity_max_usage)"

  if [ "$before" -lt "$WARN_PERCENT" ] && [ "$extra_before" -lt "$EXTRA_WARN_PERCENT" ]; then
    log "OK: root and extra capacity below warn thresholds"
    write_status "ok" "before=${before}% threshold=${WARN_PERCENT}%${extra_status}"
    exit 0
  fi

  if [ "$before" -lt "$CLEAN_PERCENT" ] && [ "$extra_before" -lt "$EXTRA_CLEAN_PERCENT" ]; then
    log "WARN: capacity above a warn threshold but below cleanup thresholds; no cleanup"
    write_status "warning" "before=${before}% warn=${WARN_PERCENT}% cleanup=${CLEAN_PERCENT}%${extra_status}"
    exit 0
  fi

  emergency="false"
  if [ "$before" -ge "$CRITICAL_PERCENT" ] || [ "$extra_before" -ge "$EXTRA_CRITICAL_PERCENT" ]; then
    emergency="true"
  fi

  safe_log_maintenance
  safe_cache_maintenance "$emergency"

  after="$(usage_percent)"
  extra_after="$(extra_capacity_max_usage)"
  effective_before="$before"
  effective_after="$after"
  if [ "$extra_before" -gt "$effective_before" ]; then
    effective_before="$extra_before"
  fi
  if [ "$extra_after" -gt "$effective_after" ]; then
    effective_after="$extra_after"
  fi
  log "DONE: root ${before}% -> ${after}%; max extra ${extra_before}% -> ${extra_after}%"
  record_cleanup_result "$effective_before" "$effective_after"

  extra_status="$(extra_capacity_status)"
  if [ -n "$extra_status" ]; then
    local current_status
    current_status="$(cat "$STATUS_FILE" 2>/dev/null || true)"
    printf '%s%s\n' "$current_status" "$extra_status" >"$STATUS_FILE"
  fi

  if [ "$after" -ge "$CRITICAL_PERCENT" ] || [ "$extra_after" -ge "$EXTRA_CRITICAL_PERCENT" ]; then
    log "CRITICAL: a capacity path remains above its critical threshold; manual review required"
  fi
}

main "$@"
